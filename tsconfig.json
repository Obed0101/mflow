{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@mflow/shared": ["./packages/shared/src"],
      "@mflow/shared/*": ["./packages/shared/src/*"],
      "@mflow/daemon": ["./packages/daemon/src"],
      "@mflow/daemon/*": ["./packages/daemon/src/*"],
      "@mflow/signaling": ["./packages/signaling/src"],
      "@mflow/signaling/*": ["./packages/signaling/src/*"],
      "@mflow/cli": ["./packages/cli/src"],
      "@mflow/cli/*": ["./packages/cli/src/*"],
      "@mflow/mcp": ["./packages/mcp/src"],
      "@mflow/mcp/*": ["./packages/mcp/src/*"]
    }
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/daemon" },
    { "path": "packages/signaling" },
    { "path": "packages/cli" },
    { "path": "packages/mcp" }
  ],
  "files": [],
  "exclude": ["node_modules", "dist"]
}
