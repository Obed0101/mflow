{
  "name": "mflow-cli",
  "private": false,
  "version": "0.1.10",
  "description": "Sync local worktrees so AI agents and humans stop overwriting each other",
  "homepage": "https://github.com/Obed0101/mflow#readme",
  "bugs": {
    "url": "https://github.com/Obed0101/mflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Obed0101/mflow.git"
  },
  "bin": {
    "mflow": "packages/cli/src/index.ts",
    "mflow-mcp": "packages/mcp/src/index.ts"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    ".env.example",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "scripts/check-public-release.sh",
    "skills/",
    "docs/",
    "packages/*/src/**",
    "packages/*/package.json",
    "packages/*/tsconfig.json",
    "packages/cli/daemon-entry.ts",
    "packages/signaling/.dockerignore",
    "packages/signaling/Dockerfile",
    "packages/signaling/deno-deploy.ts",
    "bunfig.toml",
    "deno.jsonc",
    "tsconfig.json"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:signaling": "bun --cwd packages/signaling --env-file=../../.env.local src/index.ts",
    "dev:daemon": "bun run --cwd packages/daemon src/index.ts",
    "test": "bun test",
    "test:integration": "bun test tests/integration/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "fast-diff": "^1.3.0",
    "xxhash-wasm": "^1.1.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.18",
    "ip-address": "^10.2.0",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4"
  }
}
